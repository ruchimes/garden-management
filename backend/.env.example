# Variables de entorno para el backend (Render)
# Configúralas en: Render → tu servicio → Environment

# Connection string de MongoDB Atlas
# MongoDB Atlas → tu cluster → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nombre de la base de datos (se crea automáticamente si no existe)
MONGODB_DB=huerto

# Secreto para proteger los endpoints /api/sync
# Usa cualquier string largo y aleatorio. Debe coincidir con VITE_API_SECRET en Vercel.
API_SECRET=

# URL del frontend (para CORS). Pon la URL de tu app en Vercel.
# Acepta varias URLs separadas por coma, o * para desarrollo.
ALLOWED_ORIGIN=https://tu-app.vercel.app
