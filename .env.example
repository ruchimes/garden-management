# Variables de entorno para HuertoApp
# Copia este fichero como .env.local para desarrollo local
# En Vercel: Settings → Environment Variables

# URL del servidor CouchDB (sin slash final)
VITE_COUCH_URL=https://garden-management-bvys.onrender.com

# Credenciales CouchDB (las mismas que en Render)
VITE_COUCH_USER=admin
VITE_COUCH_PASS=tu_contraseña_aquí
