# Variables de entorno para HuertoApp (frontend — Vercel)
# Copia este fichero como .env.local para desarrollo local
# En Vercel: Settings → Environment Variables

# URL del backend en Render (sin slash final)
# Desarrollo local: http://localhost:4000
# Producción:       https://huerto-backend.onrender.com
VITE_API_BASE=https://huerto-backend.onrender.com

# Secreto para proteger los endpoints del backend.
# Debe coincidir con API_SECRET en las variables de entorno de Render.
VITE_API_SECRET=

# Desactiva la sincronización en la nube (útil para pruebas offline)
# VITE_MONGO_ENABLED=false
